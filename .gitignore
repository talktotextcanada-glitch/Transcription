# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
*.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large audio/video files and test data
*.mp3
*.mp4
*.wav
*.m4a
# Exception for tutorial video in public directory
!public/tutorial-video.mp4
*.avi
*.mov
*.zip
*.rar
*.7z

# Client test files and transcripts
client/signofthecross_*
client/*_transcript*
client/*.zip
client/client_data/
client/cv-corpus-*
client/dev-other*
client/*.tar.gz

*.md
client/templates/
